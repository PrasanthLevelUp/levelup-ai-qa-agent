# The optional multi-language parsers (tree-sitter-c-sharp / tree-sitter-java)
# declare a peer dependency on tree-sitter@^0.21.x, while this project pins
# tree-sitter@^0.25.0 (required by tree-sitter-python). The native ABI is
# compatible and these parsers are loaded lazily and gated behind a feature
# flag (ENABLE_MULTI_LANGUAGE), so the strict peer range is overly conservative.
# legacy-peer-deps lets `npm ci` / `npm install` resolve without ERESOLVE while
# keeping these dependencies truly optional.
legacy-peer-deps=true

# =============================================================================
# LevelUp AI QA Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# SECURITY: Never commit .env to version control!

# --- API Authentication ---
# Comma-separated list of valid API keys for authenticating API requests.
# Example: API_KEYS=my_dev_key,my_prod_key
API_KEYS=your_dev_key_here,your_prod_key_here

# --- OpenAI ---
# Required for AI Engine (Level 3 healing). Get from https://platform.openai.com
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# --- GitHub ---
# Personal Access Token for creating PRs and pushing fixes.
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# --- Database (PostgreSQL) ---
# PostgreSQL connection string.
# Format: postgresql://user:password@host:port/database
# For Railway: Use the DATABASE_URL provided by Railway PostgreSQL addon
DATABASE_URL=postgresql://user:password@localhost:5432/levelup_qa

# Set to 'false' to disable SSL (for local development)
DATABASE_SSL=true

# --- Server ---
# Port for the REST API server.
PORT=8080

# Operating mode: "api" for REST API server, "cli" for command-line mode.
MODE=api

# Logging verbosity: debug, info, warn, error
LOG_LEVEL=info

# --- Reports ---
# Directory for HTML healing reports.
REPORT_DIR=/home/ubuntu/healing_reports

# --- GitHub Webhook (optional) ---
# Secret for validating GitHub webhook signatures.
GITHUB_WEBHOOK_SECRET=

# --- Healing Strategy ---
# Maximum daily token budget for AI engine (in tokens).
MAX_DAILY_TOKEN_BUDGET=100000

# Maximum cost per healing attempt (in USD).
MAX_COST_PER_HEALING=0.10

# --- Healing Performance / Safety Budgets ---
# These bound how long a healing job can run so it always completes in a
# reasonable time (instead of hanging for hours on a slow/flaky test).
# Total wall-clock budget for an entire healing job (ms). Default 900000 = 15 min.
HEALING_JOB_BUDGET_MS=900000
# Wall-clock budget per individual test (ms). Default 240000 = 4 min.
HEALING_PER_TEST_BUDGET_MS=240000
# Timeout for a single Playwright test rerun (ms). Default 120000 = 2 min.
HEALING_RERUN_TIMEOUT_MS=120000
# The test repo's own per-action/per-test timeout (ms). Playwright's default is
# 30000 (30s) when playwright.config sets none. A broken locator does NOT error
# immediately — fill()/click() WAIT this long, and Playwright only emits its
# locator-rich, *located* error when this fires naturally. A validation rerun is
# therefore only trustworthy if allowed to run at least this long, so the healer
# never starts (or kills) a rerun below REPO_ACTION_TIMEOUT + RERUN_BUFFER. Raise
# this if your repo configures a larger test timeout. Default 30000 = 30s.
HEALING_REPO_ACTION_TIMEOUT_MS=30000
# Headroom added on top of the action timeout (browser launch, navigation,
# reporter flush, trace write) so a rerun finishes a clean, parseable result.
# Default 15000 = 15s → minimum trustworthy rerun budget = 45s.
HEALING_RERUN_BUFFER_MS=15000
# Max distinct broken locators to fix per test before giving up. Default 6.
HEALING_MAX_ITERATIONS=6
# Max candidate suggestions to examine per broken locator. Default 3.
HEALING_RETRIES_PER_LOCATOR=3

# --- Candidate Ranking (run the browser far fewer times) ---
# Candidates from every layer (Learned Pattern, App Profile, DOM Memory, DOM,
# Rule, AI) are collected and RANKED with cheap browser-free heuristics, so only
# the best candidate(s) ever launch Playwright. This is the biggest healing-time
# lever — it replaces the old "one browser rerun per candidate" behaviour.
# Hard cap on browser reruns per broken locator (best candidate tried first).
# Default 2 (was effectively HEALING_RETRIES_PER_LOCATOR browser runs).
HEALING_MAX_BROWSER_TRIES_PER_LOCATOR=2
# Skip the AI top-up when at least this many grounded candidates already clear
# the confidence bar below (keeps token spend down). Default 2.
HEALING_RANK_MIN_GROUNDED=2
# A grounded candidate at/above this confidence counts toward MIN_GROUNDED. Default 0.8.
HEALING_RANK_AI_SKIP_CONFIDENCE=0.8
# Ranking weights (browser-free signals). Defaults sum-weighted; retune as needed.
HEALING_RANK_W_CONFIDENCE=0.4
HEALING_RANK_W_SOURCE=0.3
HEALING_RANK_W_APP_PROFILE=0.1
HEALING_RANK_W_DOM_MEMORY=0.1
HEALING_RANK_W_PAGE_OBJECT=0.05
HEALING_RANK_W_SIMILARITY=0.05

# Hard timeout for each OpenAI API request (ms). Default 30000 = 30s.
OPENAI_TIMEOUT_MS=30000
# Our own bounded retry count for OpenAI calls (total attempts = retries + 1). Default 1.
OPENAI_MAX_RETRIES=1

# --- AI Cost Optimization ---
# Primary model for most AI tasks (healing, test gen, RCA). Recommended: gpt-4o-mini
OPENAI_PRIMARY_MODEL=gpt-4o-mini

# Embedding model for similarity matching (99% cheaper than LLM)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Premium model — ONLY for enterprise demos / complex reasoning. NEVER for healing loops.
OPENAI_PREMIUM_MODEL=gpt-4o

# Enable premium model usage (set to 'false' for MVP to prevent accidental expensive calls)
ENABLE_PREMIUM_MODE=false

# --- Anthropic (Claude) — Phase 1 quality validation ---
# Optional. Lets Script Generation, Test Generation and Test → Script use Claude
# instead of OpenAI. ONLY these three features are affected; healing, RCA,
# embeddings, AI review and migrations are unchanged. If Anthropic is not
# configured or a call fails, the system transparently falls back to OpenAI.
#
# API key (required to enable Claude). Leave unset to keep everything on OpenAI.
ANTHROPIC_API_KEY=

# Per-feature provider switch: 'openai' (default) or 'anthropic'.
SCRIPT_PROVIDER=openai
TEST_PROVIDER=openai

# Model used when the matching provider is 'anthropic'. Friendly aliases
# (claude-sonnet, claude-opus, claude-haiku) resolve to concrete Claude model
# ids; a full Anthropic model id may also be given verbatim.
SCRIPT_MODEL=claude-sonnet
TEST_MODEL=claude-sonnet

# Optional resilience tunables for the Anthropic client (mirror the OpenAI ones).
ANTHROPIC_TIMEOUT_MS=60000
ANTHROPIC_MAX_RETRIES=1

# Maximum daily AI spend in USD (prevents runaway costs). Recommended: $5/day for MVP
MAX_DAILY_AI_COST_USD=5.00

# Maximum tokens per single AI request (prevents huge prompts)
MAX_TOKENS_PER_REQUEST=4000

# Budget warning threshold (fraction of daily budget that triggers warnings)
COST_WARNING_THRESHOLD=0.80

# ─── Adaptive generation tiers ───────────────────────────────────────────────
# Test-case generation budget is made PROPORTIONAL to requirement complexity.
# A pure heuristic (ZERO LLM tokens) computes a weighted complexity score from
# cheap signals (requirement chars, AC count, coverage types, flow steps,
# intelligence sources) and routes each requirement to FAST / STANDARD /
# COMPREHENSIVE. The tier scales output-token + prompt-char budgets and whether
# the separate analysis LLM call runs. Only COMPREHENSIVE runs analysis; FAST/
# STANDARD derive it heuristically (saves a round-trip on small reqs). The
# generation prompt is identical across tiers — quality is NOT reduced.
# All tunables below are optional; sensible defaults apply if unset. Tune from
# the telemetry recorded per generation (complexityScore, tier, tokens, durations).

# --- Tier budgets ---
GEN_FAST_MAX_TOKENS=2500
GEN_FAST_MAX_PROMPT_CHARS=24000
# STANDARD lowered 5000 → 3500: fewer, higher-quality scenarios per generation
# for typical single-feature requirements (grounding is unchanged).
GEN_STANDARD_MAX_TOKENS=3500
GEN_STANDARD_MAX_PROMPT_CHARS=40000
GEN_COMPREHENSIVE_MAX_TOKENS=8000
GEN_COMPREHENSIVE_MAX_PROMPT_CHARS=60000

# --- Complexity scoring weights (0.0–1.0; sum normalized to 1.0 internally) ---
# Philosophy: complexity is an INTRINSIC property of the requirement (how much real
# testable surface it describes), NOT of how many coverage types the user ticked.
# Coverage-type count and intelligence-source count express user INTENT / available
# grounding, so they carry only minor weight (0.10 each). Requirement size and
# acceptance-criteria density dominate. This keeps simple requests like "User Login"
# in FAST/STANDARD even when many coverage types are selected.
# Tune after collecting a few thousand telemetry samples.
GEN_WEIGHT_REQ_CHARS=0.40
GEN_WEIGHT_AC=0.25
GEN_WEIGHT_FLOW=0.15
GEN_WEIGHT_COVERAGE_TYPES=0.10
GEN_WEIGHT_SOURCES=0.10

# --- Score thresholds (0-100 scale) for tier classification ---
# Composite score < FAST_THRESHOLD → FAST
# < STANDARD_THRESHOLD → STANDARD
# ≥ STANDARD_THRESHOLD → COMPREHENSIVE
# STANDARD_THRESHOLD raised 40 → 45 so only genuinely large/detailed requirements
# (long prose, many AC, multi-step flows) reach COMPREHENSIVE and its 8K budget.
GEN_FAST_THRESHOLD=25
GEN_STANDARD_THRESHOLD=45

# --- Gap-analysis complexity gate (Test Case Lab) ---
# Gap analysis is a separate LLM round-trip. Skip it for simple, solved-problem
# requirements (login, logout, forgot-password, search) whose composite
# complexity score is below this gate. It still runs for genuinely complex flows
# (banking, insurance, multi-step checkout, approval workflows) when the caller
# requests it. Set to 0 to always run gap analysis when requested.
GEN_GAP_ANALYSIS_MIN_COMPLEXITY=35

# --- Scenario Planner (QA-first, AI-assisted architecture) ---
# When ON, a deterministic (zero-LLM) planner classifies the requirement into a
# QA category (authentication, crud, search, checkout, payment, admin, workflow,
# reporting, import, export) and injects the senior-QA baseline scenarios for
# that category into the generation prompt as a plan to EXPAND. The LLM enriches
# known-good obligations instead of re-deriving what to test — improving
# consistency and letting the generator run a tighter output budget. The plan is
# filtered to the user's selected coverage types and NEVER overrides grounding
# (planned scenarios are candidates the LLM keeps only if the requirement/context
# supports them). Unknown categories emit no plan → identical to legacy behaviour.
# Set to false to disable and fall back to the plan-free prompt.
GEN_SCENARIO_PLANNER=true

# --- Prompt Optimizer (QA-first token reduction) ---
# The INPUT prompt — not the generated output — is the dominant token cost.
# When ON, a deterministic (zero-LLM) optimizer trims the grounding context sent
# to the model down to what the requirement's QA category actually needs BEFORE
# the prompt is assembled: it drops crawled app-profile pages/forms/elements and
# test-data sets that are irrelevant to the category (e.g. it will not ship the
# Products/Cart/Checkout/Search pages for a "User Login" requirement). This can
# cut a large chunk of input tokens with no loss of relevant grounding.
# Fail-open by design: for `generic`/low-confidence requirements or small
# profiles the context is passed through UNCHANGED (byte-for-byte legacy prompt),
# a safe floor of items is always kept, and the original object is never mutated.
# Set to false to always send the full grounding context (legacy behaviour).
GEN_PROMPT_OPTIMIZER=true
# Minimum category-classification confidence (0-1) before the optimizer trims.
GEN_PROMPT_OPTIMIZER_MIN_CONFIDENCE=0.5

# --- Token analytics / cost estimate ---
# Per-1K-token rates used ONLY for the rough USD cost estimate surfaced with each
# generation (stats.estimatedCostUsd + generationMetadata). These do not affect
# generation — they let the UI show an at-a-glance cost without a hard dependency
# on live pricing. Override to match your provider's actual rates.
TOKEN_COST_INPUT_PER_1K=0.003
TOKEN_COST_OUTPUT_PER_1K=0.015


# ─── Healing reports (object storage) ────────────────────────────────────────
# Healing reports are platform-owned metadata: the DOCUMENT is stored here and only
# an opaque reference (report_uri) is kept in Postgres — the customer repo never
# contains a healing-reports/ folder. Default is a local/Railway-style persistent
# volume; later this can point at S3/GCS/Azure by adding a store implementation
# (see src/reports/report-store.ts) without any DB migration.
REPORTS_DIR=/data/reports

# ─── Security ────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -hex 32
# 64 hex character string (32 bytes) for AES-256-GCM credential encryption.
CREDENTIAL_ENCRYPTION_KEY=

# REQUIRED in production. Generate with: openssl rand -base64 48
# At least 32 characters. Used for signing JWT session tokens.
# IMPORTANT: this exact value MUST also be set on the dashboard
# (levelup-ai-qa-dashboard), which verifies the session cookie this API signs.
# If they differ, login succeeds but every authed request returns 401.
# In production the server refuses to boot if this is unset or < 32 chars.
# See docs/security/jwt-secret-setup.md
JWT_SECRET=

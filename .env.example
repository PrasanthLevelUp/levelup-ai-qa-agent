# =============================================================================
# LevelUp AI QA Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# SECURITY: Never commit .env to version control!

# --- API Authentication ---
# Comma-separated list of valid API keys for authenticating API requests.
# Example: API_KEYS=my_dev_key,my_prod_key
API_KEYS=your_dev_key_here,your_prod_key_here

# --- OpenAI ---
# Required for AI Engine (Level 3 healing). Get from https://platform.openai.com
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# --- GitHub ---
# Personal Access Token for creating PRs and pushing fixes.
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# --- Database (PostgreSQL) ---
# PostgreSQL connection string.
# Format: postgresql://user:password@host:port/database
# For Railway: Use the DATABASE_URL provided by Railway PostgreSQL addon
DATABASE_URL=postgresql://user:password@localhost:5432/levelup_qa

# Set to 'false' to disable SSL (for local development)
DATABASE_SSL=true

# --- Server ---
# Port for the REST API server.
PORT=8080

# Operating mode: "api" for REST API server, "cli" for command-line mode.
MODE=api

# Logging verbosity: debug, info, warn, error
LOG_LEVEL=info

# --- Reports ---
# Directory for HTML healing reports.
REPORT_DIR=/home/ubuntu/healing_reports

# --- GitHub Webhook (optional) ---
# Secret for validating GitHub webhook signatures.
GITHUB_WEBHOOK_SECRET=

# --- Healing Strategy ---
# Maximum daily token budget for AI engine (in tokens).
MAX_DAILY_TOKEN_BUDGET=100000

# Maximum cost per healing attempt (in USD).
MAX_COST_PER_HEALING=0.10

# =============================================================================
# LevelUp AI QA Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# SECURITY: Never commit .env to version control!

# --- API Authentication ---
# Comma-separated list of valid API keys for authenticating API requests.
# Example: API_KEYS=my_dev_key,my_prod_key
API_KEYS=your_dev_key_here,your_prod_key_here

# --- OpenAI ---
# Required for AI Engine (Level 3 healing). Get from https://platform.openai.com
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# --- GitHub ---
# Personal Access Token for creating PRs and pushing fixes.
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# --- Database (PostgreSQL) ---
# PostgreSQL connection string.
# Format: postgresql://user:password@host:port/database
# For Railway: Use the DATABASE_URL provided by Railway PostgreSQL addon
DATABASE_URL=postgresql://user:password@localhost:5432/levelup_qa

# Set to 'false' to disable SSL (for local development)
DATABASE_SSL=true

# --- Server ---
# Port for the REST API server.
PORT=8080

# Operating mode: "api" for REST API server, "cli" for command-line mode.
MODE=api

# Logging verbosity: debug, info, warn, error
LOG_LEVEL=info

# --- Reports ---
# Directory for HTML healing reports.
REPORT_DIR=/home/ubuntu/healing_reports

# --- GitHub Webhook (optional) ---
# Secret for validating GitHub webhook signatures.
GITHUB_WEBHOOK_SECRET=

# --- Healing Strategy ---
# Maximum daily token budget for AI engine (in tokens).
MAX_DAILY_TOKEN_BUDGET=100000

# Maximum cost per healing attempt (in USD).
MAX_COST_PER_HEALING=0.10

# --- AI Cost Optimization ---
# Primary model for most AI tasks (healing, test gen, RCA). Recommended: gpt-4o-mini
OPENAI_PRIMARY_MODEL=gpt-4o-mini

# Embedding model for similarity matching (99% cheaper than LLM)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Premium model — ONLY for enterprise demos / complex reasoning. NEVER for healing loops.
OPENAI_PREMIUM_MODEL=gpt-4o

# Enable premium model usage (set to 'false' for MVP to prevent accidental expensive calls)
ENABLE_PREMIUM_MODE=false

# Maximum daily AI spend in USD (prevents runaway costs). Recommended: $5/day for MVP
MAX_DAILY_AI_COST_USD=5.00

# Maximum tokens per single AI request (prevents huge prompts)
MAX_TOKENS_PER_REQUEST=4000

# Budget warning threshold (fraction of daily budget that triggers warnings)
COST_WARNING_THRESHOLD=0.80


# ─── Security ────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -hex 32
# 64 hex character string (32 bytes) for AES-256-GCM credential encryption.
CREDENTIAL_ENCRYPTION_KEY=

# REQUIRED in production. Generate with: openssl rand -base64 48
# At least 32 characters. Used for signing JWT session tokens.
JWT_SECRET=

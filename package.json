{
  "name": "levelup-ai-qa-agent",
  "version": "2.0.0",
  "description": "AI-powered self-healing test automation agent with REST API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "postinstall": "playwright install --with-deps chromium",
    "start": "node dist/index.js",
    "start:api": "MODE=api ts-node src/index.ts",
    "start:cli": "MODE=cli ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
    "dev:api": "MODE=api ts-node src/index.ts",
    "run-tests": "ts-node src/core/execution-engine.ts",
    "report": "ts-node src/reports/html-report.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PrasanthLevelUp/levelup-ai-qa-agent.git"
  },
  "keywords": [
    "qa",
    "testing",
    "self-healing",
    "playwright",
    "automation",
    "api"
  ],
  "author": "PrasanthLevelUp",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "diff": "^8.0.2",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.37.0",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "prisma": "^6.7.0",
    "ts-morph": "^21.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
